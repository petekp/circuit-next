{
  "schema_version": "2",
  "id": "explore",
  "version": "0.1.0",
  "purpose": "Phase 2 first-parity target workflow per ADR-0007 CC#P2-1. Full-spine investigation: frame → analyze → synthesize → review → close. Canonical phase set {frame, analyze, act, review, close} with omits=[plan, verify] per explore contract §Canonical phase set. Synthesize and Review are worker-dispatch steps per ADR-0008 (distinct-adapter Knight-Leveson boundary crossings); Frame, Analyze, and Close remain orchestrator-synthesis (framing, decomposition, aggregation).",
  "entry": {
    "signals": {
      "include": ["explore", "investigate", "research", "understand"],
      "exclude": []
    },
    "intent_prefixes": ["explore", "investigate"]
  },
  "entry_modes": [
    {
      "name": "default",
      "start_at": "frame-step",
      "rigor": "standard",
      "description": "Default explore entry mode — seeds the run at Frame. Standard rigor per ADR-0007 CC#P2-6 resolution of plan Open Question #5."
    }
  ],
  "phases": [
    {
      "id": "frame-phase",
      "title": "Frame",
      "canonical": "frame",
      "steps": ["frame-step"]
    },
    {
      "id": "analyze-phase",
      "title": "Analyze",
      "canonical": "analyze",
      "steps": ["analyze-step"]
    },
    {
      "id": "synthesize-phase",
      "title": "Synthesize",
      "canonical": "act",
      "steps": ["synthesize-step"]
    },
    {
      "id": "review-phase",
      "title": "Review",
      "canonical": "review",
      "steps": ["review-step"]
    },
    {
      "id": "close-phase",
      "title": "Close",
      "canonical": "close",
      "steps": ["close-step"]
    }
  ],
  "spine_policy": {
    "mode": "partial",
    "omits": ["plan", "verify"],
    "rationale": "Explore is an investigation workflow — plan-mode is folded into Frame (investigation scoping); verify is omitted because explore output is not executable and does not admit mechanical verification. Review is the adversarial pass that IS in scope and, per ADR-0008, is a distinct-adapter review dispatch (not a weaker substitute for verify as previously described at v0.1 authoring). See specs/contracts/explore.md §Canonical phase set for the full rationale."
  },
  "steps": [
    {
      "id": "frame-step",
      "title": "Frame — produce explore.brief",
      "protocol": "explore-frame@v1",
      "reads": [],
      "routes": {
        "pass": "analyze-step"
      },
      "executor": "orchestrator",
      "kind": "synthesis",
      "writes": {
        "artifact": {
          "path": "artifacts/brief.json",
          "schema": "explore.brief@v1"
        }
      },
      "gate": {
        "kind": "schema_sections",
        "source": {
          "kind": "artifact",
          "ref": "artifact"
        },
        "required": ["subject", "success_condition"]
      }
    },
    {
      "id": "analyze-step",
      "title": "Analyze — produce explore.analysis",
      "protocol": "explore-analyze@v1",
      "reads": ["artifacts/brief.json"],
      "routes": {
        "pass": "synthesize-step"
      },
      "executor": "orchestrator",
      "kind": "synthesis",
      "writes": {
        "artifact": {
          "path": "artifacts/analysis.json",
          "schema": "explore.analysis@v1"
        }
      },
      "gate": {
        "kind": "schema_sections",
        "source": {
          "kind": "artifact",
          "ref": "artifact"
        },
        "required": ["aspects"]
      }
    },
    {
      "id": "synthesize-step",
      "title": "Synthesize — produce explore.synthesis (adapter-bound dispatch per ADR-0008)",
      "protocol": "explore-synthesize@v1",
      "reads": ["artifacts/brief.json", "artifacts/analysis.json"],
      "routes": {
        "pass": "review-step"
      },
      "executor": "worker",
      "kind": "dispatch",
      "role": "implementer",
      "writes": {
        "artifact": {
          "path": "artifacts/synthesis.json",
          "schema": "explore.synthesis@v1"
        },
        "request": "artifacts/dispatch/synthesize.request.json",
        "receipt": "artifacts/dispatch/synthesize.receipt.txt",
        "result": "artifacts/dispatch/synthesize.result.json"
      },
      "gate": {
        "kind": "result_verdict",
        "source": {
          "kind": "dispatch_result",
          "ref": "result"
        },
        "pass": ["accept"]
      }
    },
    {
      "id": "review-step",
      "title": "Review — adversarial pass over synthesis (adapter-bound dispatch per ADR-0008)",
      "protocol": "explore-review@v1",
      "reads": ["artifacts/brief.json", "artifacts/analysis.json", "artifacts/synthesis.json"],
      "routes": {
        "pass": "close-step"
      },
      "executor": "worker",
      "kind": "dispatch",
      "role": "reviewer",
      "writes": {
        "artifact": {
          "path": "artifacts/review-verdict.json",
          "schema": "explore.review-verdict@v1"
        },
        "request": "artifacts/dispatch/review.request.json",
        "receipt": "artifacts/dispatch/review.receipt.txt",
        "result": "artifacts/dispatch/review.result.json"
      },
      "gate": {
        "kind": "result_verdict",
        "source": {
          "kind": "dispatch_result",
          "ref": "result"
        },
        "pass": ["accept", "accept-with-fold-ins"]
      }
    },
    {
      "id": "close-step",
      "title": "Close — emit final result artifact",
      "protocol": "explore-close@v1",
      "reads": [
        "artifacts/brief.json",
        "artifacts/synthesis.json",
        "artifacts/review-verdict.json"
      ],
      "routes": {
        "pass": "@complete"
      },
      "executor": "orchestrator",
      "kind": "synthesis",
      "writes": {
        "artifact": {
          "path": "artifacts/explore-result.json",
          "schema": "explore.result@v1"
        }
      },
      "gate": {
        "kind": "schema_sections",
        "source": {
          "kind": "artifact",
          "ref": "artifact"
        },
        "required": ["summary", "verdict_snapshot"]
      }
    }
  ]
}
