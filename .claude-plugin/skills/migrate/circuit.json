{
  "schema_version": "2",
  "id": "migrate",
  "version": "0.1.0",
  "purpose": "Large-scale migrations: framework swaps, dependency replacements, architecture transitions, incremental rewrites. Frame the migration's source and target, inventory what needs to move, plan the coexistence window and rollback path, execute the migration through a sub-run that delegates the actual code change to a Build child workflow, verify nothing regressed, run a cutover review, and close with evidence. v0 default executor: sub-run sequential per batch (single batch at v0). The fanout-over-batches expansion lands once the WorktreeRunner CLI wiring is in place.",
  "entry": {
    "signals": {
      "include": [
        "migrate",
        "migration",
        "framework-swap",
        "rewrite",
        "dependency-replacement",
        "architecture-transition"
      ],
      "exclude": []
    },
    "intent_prefixes": ["migrate", "rewrite"]
  },
  "entry_modes": [
    {
      "name": "default",
      "start_at": "frame-step",
      "rigor": "standard",
      "description": "Default Migrate entry mode."
    },
    {
      "name": "lite",
      "start_at": "frame-step",
      "rigor": "lite",
      "description": "Lite Migrate entry mode."
    },
    {
      "name": "deep",
      "start_at": "frame-step",
      "rigor": "deep",
      "description": "Deep Migrate entry mode."
    },
    {
      "name": "autonomous",
      "start_at": "frame-step",
      "rigor": "autonomous",
      "description": "Autonomous Migrate entry mode."
    }
  ],
  "phases": [
    {
      "id": "frame-phase",
      "title": "Frame",
      "canonical": "frame",
      "steps": ["frame-step"]
    },
    {
      "id": "inventory-phase",
      "title": "Inventory",
      "canonical": "analyze",
      "steps": ["inventory-step"]
    },
    {
      "id": "coexistence-phase",
      "title": "Coexistence Plan",
      "canonical": "plan",
      "steps": ["coexistence-step"]
    },
    {
      "id": "execute-phase",
      "title": "Batch Execution",
      "canonical": "act",
      "steps": ["batch-step"]
    },
    {
      "id": "verify-phase",
      "title": "Verify",
      "canonical": "verify",
      "steps": ["verify-step"]
    },
    {
      "id": "review-phase",
      "title": "Cutover Review",
      "canonical": "review",
      "steps": ["review-step"]
    },
    {
      "id": "close-phase",
      "title": "Close",
      "canonical": "close",
      "steps": ["close-step"]
    }
  ],
  "spine_policy": {
    "mode": "strict"
  },
  "steps": [
    {
      "id": "frame-step",
      "title": "Frame - produce Migrate brief",
      "protocol": "migrate-frame@v1",
      "reads": [],
      "routes": {
        "pass": "inventory-step"
      },
      "executor": "orchestrator",
      "kind": "synthesis",
      "writes": {
        "artifact": {
          "path": "artifacts/migrate/brief.json",
          "schema": "migrate.brief@v1"
        }
      },
      "gate": {
        "kind": "schema_sections",
        "source": {
          "kind": "artifact",
          "ref": "artifact"
        },
        "required": ["objective", "source", "target"]
      }
    },
    {
      "id": "inventory-step",
      "title": "Inventory - enumerate migration targets and group into batches",
      "protocol": "migrate-inventory@v1",
      "reads": ["artifacts/migrate/brief.json"],
      "routes": {
        "pass": "coexistence-step"
      },
      "executor": "orchestrator",
      "kind": "synthesis",
      "writes": {
        "artifact": {
          "path": "artifacts/migrate/inventory.json",
          "schema": "migrate.inventory@v1"
        }
      },
      "gate": {
        "kind": "schema_sections",
        "source": {
          "kind": "artifact",
          "ref": "artifact"
        },
        "required": ["items", "batches"]
      }
    },
    {
      "id": "coexistence-step",
      "title": "Coexistence Plan - source/target side-by-side strategy and rollback path",
      "protocol": "migrate-coexistence@v1",
      "reads": ["artifacts/migrate/brief.json", "artifacts/migrate/inventory.json"],
      "routes": {
        "pass": "batch-step"
      },
      "executor": "orchestrator",
      "kind": "synthesis",
      "writes": {
        "artifact": {
          "path": "artifacts/migrate/coexistence.json",
          "schema": "migrate.coexistence@v1"
        }
      },
      "gate": {
        "kind": "schema_sections",
        "source": {
          "kind": "artifact",
          "ref": "artifact"
        },
        "required": ["strategy", "switchover_criteria", "rollback_path"]
      }
    },
    {
      "id": "batch-step",
      "title": "Batch Execution - delegate the migration changes to a Build sub-run",
      "protocol": "migrate-batch@v1",
      "reads": ["artifacts/migrate/brief.json", "artifacts/migrate/inventory.json"],
      "routes": {
        "pass": "verify-step"
      },
      "executor": "orchestrator",
      "kind": "sub-run",
      "workflow_ref": {
        "workflow_id": "build",
        "entry_mode": "default"
      },
      "goal": "Migrate the inventoried targets per migrate.coexistence@v1 batch plan",
      "rigor": "standard",
      "writes": {
        "result": "artifacts/migrate/batch-result.json",
        "artifact": {
          "path": "artifacts/migrate/batch-result.json",
          "schema": "migrate.batch@v1"
        }
      },
      "gate": {
        "kind": "result_verdict",
        "source": {
          "kind": "sub_run_result",
          "ref": "result"
        },
        "pass": ["accept", "accept-with-fixes"]
      }
    },
    {
      "id": "verify-step",
      "title": "Verify - run Migrate verification commands",
      "protocol": "migrate-verify@v1",
      "reads": ["artifacts/migrate/brief.json", "artifacts/migrate/batch-result.json"],
      "routes": {
        "pass": "review-step"
      },
      "executor": "orchestrator",
      "kind": "verification",
      "writes": {
        "artifact": {
          "path": "artifacts/migrate/verification.json",
          "schema": "migrate.verification@v1"
        }
      },
      "gate": {
        "kind": "schema_sections",
        "source": {
          "kind": "artifact",
          "ref": "artifact"
        },
        "required": ["overall_status", "commands"]
      }
    },
    {
      "id": "review-step",
      "title": "Cutover Review - independent audit of the migration cutover",
      "protocol": "migrate-review@v1",
      "reads": [
        "artifacts/migrate/brief.json",
        "artifacts/migrate/batch-result.json",
        "artifacts/migrate/verification.json"
      ],
      "routes": {
        "pass": "close-step"
      },
      "executor": "worker",
      "kind": "dispatch",
      "role": "reviewer",
      "writes": {
        "artifact": {
          "path": "artifacts/migrate/review.json",
          "schema": "migrate.review@v1"
        },
        "request": "artifacts/dispatch/migrate-review.request.json",
        "receipt": "artifacts/dispatch/migrate-review.receipt.txt",
        "result": "artifacts/dispatch/migrate-review.result.json"
      },
      "gate": {
        "kind": "result_verdict",
        "source": {
          "kind": "dispatch_result",
          "ref": "result"
        },
        "pass": ["cutover-approved", "cutover-with-followups"]
      }
    },
    {
      "id": "close-step",
      "title": "Close - emit Migrate result",
      "protocol": "migrate-close@v1",
      "reads": [
        "artifacts/migrate/brief.json",
        "artifacts/migrate/inventory.json",
        "artifacts/migrate/coexistence.json",
        "artifacts/migrate/batch-result.json",
        "artifacts/migrate/verification.json",
        "artifacts/migrate/review.json"
      ],
      "routes": {
        "pass": "@complete"
      },
      "executor": "orchestrator",
      "kind": "synthesis",
      "writes": {
        "artifact": {
          "path": "artifacts/migrate-result.json",
          "schema": "migrate.result@v1"
        }
      },
      "gate": {
        "kind": "schema_sections",
        "source": {
          "kind": "artifact",
          "ref": "artifact"
        },
        "required": ["summary", "outcome", "artifact_pointers"]
      }
    }
  ]
}
