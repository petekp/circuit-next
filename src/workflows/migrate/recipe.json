{
  "schema_version": "1",
  "id": "migrate",
  "title": "Migrate Recipe",
  "purpose": "Large-scale migrations: framework swaps, dependency replacements, architecture transitions, incremental rewrites. Frame the migration's source and target, inventory what needs to move, plan the coexistence window and rollback path, execute the migration through a sub-run that delegates the actual code change to a Build child workflow, verify nothing regressed, run a cutover review, and close with evidence. v0 default executor: sub-run sequential per batch (single batch at v0). The fanout-over-batches expansion lands once the WorktreeRunner CLI wiring is in place.",
  "status": "active",
  "version": "0.1.0",
  "starts_at": "frame-step",
  "initial_contracts": [
    "task.intake@v1",
    "route.decision@v1",
    "context.packet@v1",
    "verification.plan@v1"
  ],
  "contract_aliases": [
    { "generic": "workflow.brief@v1", "actual": "migrate.brief@v1" },
    { "generic": "diagnosis.result@v1", "actual": "migrate.inventory@v1" },
    { "generic": "work.queue@v1", "actual": "migrate.inventory@v1" },
    { "generic": "plan.strategy@v1", "actual": "migrate.coexistence@v1" },
    { "generic": "change.evidence@v1", "actual": "migrate.batch@v1" },
    { "generic": "batch.result@v1", "actual": "migrate.batch@v1" },
    { "generic": "verification.result@v1", "actual": "migrate.verification@v1" },
    { "generic": "review.verdict@v1", "actual": "migrate.review@v1" },
    { "generic": "workflow.result@v1", "actual": "migrate.result@v1" }
  ],
  "entry": {
    "signals": {
      "include": [
        "migrate",
        "migration",
        "framework-swap",
        "rewrite",
        "dependency-replacement",
        "architecture-transition"
      ],
      "exclude": []
    },
    "intent_prefixes": ["migrate", "rewrite"]
  },
  "entry_modes": [
    { "name": "default", "rigor": "standard", "description": "Default Migrate entry mode." },
    { "name": "lite", "rigor": "lite", "description": "Lite Migrate entry mode." },
    { "name": "deep", "rigor": "deep", "description": "Deep Migrate entry mode." },
    {
      "name": "autonomous",
      "rigor": "autonomous",
      "description": "Autonomous Migrate entry mode."
    }
  ],
  "spine_policy": {
    "mode": "strict"
  },
  "phases": [
    { "canonical": "frame", "id": "frame-phase", "title": "Frame" },
    { "canonical": "analyze", "id": "inventory-phase", "title": "Inventory" },
    { "canonical": "plan", "id": "coexistence-phase", "title": "Coexistence Plan" },
    { "canonical": "act", "id": "execute-phase", "title": "Batch Execution" },
    { "canonical": "verify", "id": "verify-phase", "title": "Verify" },
    { "canonical": "review", "id": "review-phase", "title": "Cutover Review" },
    { "canonical": "close", "id": "close-phase", "title": "Close" }
  ],
  "items": [
    {
      "id": "frame-step",
      "uses": "frame",
      "title": "Frame - produce Migrate brief",
      "phase": "frame",
      "input": {
        "task": "task.intake@v1",
        "route": "route.decision@v1"
      },
      "output": "migrate.brief@v1",
      "evidence_requirements": ["scope boundary", "constraints", "proof plan"],
      "execution": { "kind": "synthesis" },
      "protocol": "migrate-frame@v1",
      "writes": {
        "artifact_path": "artifacts/migrate/brief.json"
      },
      "gate": { "required": ["objective", "source", "target"] },
      "routes": {
        "continue": "inventory-step",
        "stop": "@stop"
      }
    },
    {
      "id": "inventory-step",
      "uses": "diagnose",
      "title": "Inventory - enumerate migration targets and group into batches",
      "phase": "analyze",
      "input": {
        "brief": "migrate.brief@v1",
        "context": "context.packet@v1"
      },
      "output": "migrate.inventory@v1",
      "evidence_requirements": [
        "cause hypothesis",
        "confidence",
        "reproduction status",
        "diagnostic path"
      ],
      "execution": { "kind": "dispatch", "role": "implementer" },
      "protocol": "migrate-inventory@v1",
      "writes": {
        "artifact_path": "artifacts/migrate/inventory.json",
        "request_path": "artifacts/dispatch/migrate-inventory.request.json",
        "receipt_path": "artifacts/dispatch/migrate-inventory.receipt.txt",
        "result_path": "artifacts/dispatch/migrate-inventory.result.json"
      },
      "gate": { "pass": ["accept"] },
      "routes": {
        "continue": "coexistence-step",
        "stop": "@stop"
      }
    },
    {
      "id": "coexistence-step",
      "uses": "plan",
      "title": "Coexistence Plan - source/target side-by-side strategy and rollback path",
      "phase": "plan",
      "input": {
        "brief": "migrate.brief@v1",
        "inventory": "migrate.inventory@v1"
      },
      "output": "migrate.coexistence@v1",
      "evidence_requirements": ["ordered steps", "risk notes", "proof strategy"],
      "execution": { "kind": "synthesis" },
      "protocol": "migrate-coexistence@v1",
      "writes": {
        "artifact_path": "artifacts/migrate/coexistence.json"
      },
      "gate": { "required": ["strategy", "switchover_criteria", "rollback_path"] },
      "routes": {
        "continue": "batch-step",
        "stop": "@stop"
      }
    },
    {
      "id": "batch-step",
      "uses": "batch",
      "title": "Batch Execution - delegate the migration changes to a Build sub-run",
      "phase": "act",
      "input": {
        "brief": "migrate.brief@v1",
        "queue": "migrate.inventory@v1"
      },
      "output": "migrate.batch@v1",
      "evidence_requirements": [
        "completed items",
        "skipped items",
        "blocked items",
        "failed items"
      ],
      "execution": {
        "kind": "sub-run",
        "workflow_ref": { "workflow_id": "build", "entry_mode": "default" },
        "goal": "Migrate the inventoried targets per migrate.coexistence@v1 batch plan",
        "rigor": "standard"
      },
      "protocol": "migrate-batch@v1",
      "writes": {
        "result_path": "artifacts/migrate/batch-result.json"
      },
      "gate": { "pass": ["accept", "accept-with-fixes"] },
      "routes": {
        "continue": "verify-step",
        "stop": "@stop"
      }
    },
    {
      "id": "verify-step",
      "uses": "run-verification",
      "title": "Verify - run Migrate verification commands",
      "phase": "verify",
      "input": {
        "proof": "verification.plan@v1",
        "brief": "migrate.brief@v1",
        "change": "migrate.batch@v1"
      },
      "output": "migrate.verification@v1",
      "evidence_requirements": ["command list", "exit status", "bounded output", "pass or fail"],
      "execution": { "kind": "verification" },
      "protocol": "migrate-verify@v1",
      "writes": {
        "artifact_path": "artifacts/migrate/verification.json"
      },
      "gate": { "required": ["overall_status", "commands"] },
      "routes": {
        "continue": "review-step",
        "stop": "@stop"
      }
    },
    {
      "id": "review-step",
      "uses": "review",
      "title": "Cutover Review - independent audit of the migration cutover",
      "phase": "review",
      "input": {
        "brief": "migrate.brief@v1",
        "change": "migrate.batch@v1",
        "verification": "migrate.verification@v1"
      },
      "output": "migrate.review@v1",
      "evidence_requirements": ["verdict", "findings", "confidence", "required fixes"],
      "execution": { "kind": "dispatch", "role": "reviewer" },
      "protocol": "migrate-review@v1",
      "writes": {
        "artifact_path": "artifacts/migrate/review.json",
        "request_path": "artifacts/dispatch/migrate-review.request.json",
        "receipt_path": "artifacts/dispatch/migrate-review.receipt.txt",
        "result_path": "artifacts/dispatch/migrate-review.result.json"
      },
      "gate": { "pass": ["cutover-approved", "cutover-with-followups"] },
      "routes": {
        "continue": "close-step",
        "stop": "@stop"
      }
    },
    {
      "id": "close-step",
      "uses": "close-with-evidence",
      "title": "Close - emit Migrate result",
      "phase": "close",
      "input": {
        "brief": "migrate.brief@v1",
        "inventory": "migrate.inventory@v1",
        "coexistence": "migrate.coexistence@v1",
        "batch": "migrate.batch@v1",
        "verification": "migrate.verification@v1",
        "review": "migrate.review@v1"
      },
      "output": "migrate.result@v1",
      "evidence_requirements": ["outcome", "evidence pointers", "residual risks", "follow-ups"],
      "execution": { "kind": "synthesis" },
      "protocol": "migrate-close@v1",
      "writes": {
        "artifact_path": "artifacts/migrate-result.json"
      },
      "gate": { "required": ["summary", "outcome", "artifact_pointers"] },
      "routes": {
        "complete": "@complete",
        "stop": "@stop"
      }
    }
  ]
}
