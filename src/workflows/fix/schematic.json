{
  "schema_version": "1",
  "id": "fix",
  "title": "Fix Schematic",
  "purpose": "Fix workflow: capture problem boundary, gather context, diagnose, apply a focused change, verify, review (in standard rigor), and close with evidence. Lite mode skips the review dispatch and closes immediately after verification via the fix-verify route_overrides.continue.lite override. fix-no-repro-decision and fix-handoff remain in the recipe as authoring intent for future ask/handoff routing in the runtime; they are unreachable at compile and do not appear in the emitted Workflows.",
  "status": "active",
  "version": "0.1.0",
  "starts_at": "fix-frame",
  "initial_contracts": [
    "task.intake@v1",
    "route.decision@v1",
    "context.request@v1",
    "workflow.question@v1",
    "verification.plan@v1",
    "workflow.state@v1"
  ],
  "contract_aliases": [
    {
      "generic": "workflow.brief@v1",
      "actual": "fix.brief@v1"
    },
    {
      "generic": "context.packet@v1",
      "actual": "fix.context@v1"
    },
    {
      "generic": "diagnosis.result@v1",
      "actual": "fix.diagnosis@v1"
    },
    {
      "generic": "decision.answer@v1",
      "actual": "fix.no-repro-decision@v1"
    },
    {
      "generic": "workflow.evidence@v1",
      "actual": "fix.diagnosis@v1"
    },
    {
      "generic": "change.evidence@v1",
      "actual": "fix.change@v1"
    },
    {
      "generic": "verification.result@v1",
      "actual": "fix.verification@v1"
    },
    {
      "generic": "review.verdict@v1",
      "actual": "fix.review@v1"
    },
    {
      "generic": "workflow.result@v1",
      "actual": "fix.result@v1"
    }
  ],
  "entry": {
    "signals": {
      "include": ["fix", "bug", "broken", "regression", "incident", "outage", "diagnose"],
      "exclude": []
    },
    "intent_prefixes": ["fix", "diagnose"]
  },
  "entry_modes": [
    {
      "name": "default",
      "rigor": "standard",
      "description": "Default Fix entry mode \u2014 standard rigor with full review pass."
    },
    {
      "name": "lite",
      "rigor": "lite",
      "description": "Lite Fix entry mode \u2014 skips the review dispatch and closes immediately after verification."
    },
    {
      "name": "deep",
      "rigor": "deep",
      "description": "Deep Fix entry mode \u2014 standard graph at deep rigor (more thorough analysis and review)."
    },
    {
      "name": "autonomous",
      "rigor": "autonomous",
      "description": "Autonomous Fix entry mode \u2014 standard graph at autonomous rigor; safe-default checkpoint choices apply."
    }
  ],
  "spine_policy": {
    "mode": "partial",
    "omits": ["plan"],
    "rationale": "Fix follows Frame, Analyze, Act, Verify, Review, Close. The Plan phase is omitted because Fix's planning is folded into Diagnose during the Analyze phase \u2014 there is no separate plan-of-attack artifact distinct from the diagnosis."
  },
  "phases": [
    {
      "canonical": "frame",
      "id": "frame-phase",
      "title": "Frame"
    },
    {
      "canonical": "analyze",
      "id": "analyze-phase",
      "title": "Analyze"
    },
    {
      "canonical": "act",
      "id": "act-phase",
      "title": "Act"
    },
    {
      "canonical": "verify",
      "id": "verify-phase",
      "title": "Verify"
    },
    {
      "canonical": "review",
      "id": "review-phase",
      "title": "Review"
    },
    {
      "canonical": "close",
      "id": "close-phase",
      "title": "Close"
    }
  ],
  "items": [
    {
      "id": "fix-frame",
      "title": "Frame \u2014 confirm Fix brief",
      "phase": "frame",
      "input": {
        "task": "task.intake@v1",
        "route": "route.decision@v1"
      },
      "output": "fix.brief@v1",
      "evidence_requirements": ["scope boundary", "constraints", "proof plan"],
      "execution": {
        "kind": "synthesis"
      },
      "protocol": "fix-frame@v1",
      "writes": {
        "artifact_path": "artifacts/fix/brief.json"
      },
      "gate": {
        "required": ["problem_statement", "scope", "regression_contract", "success_criteria"]
      },
      "routes": {
        "continue": "fix-gather-context",
        "revise": "fix-frame",
        "ask": "@stop",
        "stop": "@stop"
      },
      "block": "frame"
    },
    {
      "id": "fix-gather-context",
      "title": "Analyze \u2014 gather problem context",
      "phase": "analyze",
      "input": {
        "brief": "fix.brief@v1",
        "request": "context.request@v1"
      },
      "output": "fix.context@v1",
      "evidence_requirements": ["source list", "observations", "confidence notes"],
      "execution": {
        "kind": "dispatch",
        "role": "researcher"
      },
      "protocol": "fix-gather-context@v1",
      "writes": {
        "artifact_path": "artifacts/fix/context.json",
        "request_path": "artifacts/dispatch/fix-gather-context.request.json",
        "receipt_path": "artifacts/dispatch/fix-gather-context.receipt.txt",
        "result_path": "artifacts/dispatch/fix-gather-context.result.json"
      },
      "gate": {
        "pass": ["accept"]
      },
      "routes": {
        "continue": "fix-diagnose",
        "retry": "fix-gather-context",
        "ask": "@stop",
        "stop": "@stop"
      },
      "block": "gather-context"
    },
    {
      "id": "fix-diagnose",
      "title": "Analyze \u2014 diagnose problem",
      "phase": "analyze",
      "input": {
        "brief": "fix.brief@v1",
        "context": "fix.context@v1"
      },
      "output": "fix.diagnosis@v1",
      "evidence_requirements": [
        "cause hypothesis",
        "confidence",
        "reproduction status",
        "diagnostic path"
      ],
      "execution": {
        "kind": "dispatch",
        "role": "researcher"
      },
      "protocol": "fix-diagnose@v1",
      "writes": {
        "artifact_path": "artifacts/fix/diagnosis.json",
        "request_path": "artifacts/dispatch/fix-diagnose.request.json",
        "receipt_path": "artifacts/dispatch/fix-diagnose.receipt.txt",
        "result_path": "artifacts/dispatch/fix-diagnose.result.json"
      },
      "gate": {
        "pass": ["accept"]
      },
      "routes": {
        "continue": "fix-act",
        "retry": "fix-gather-context",
        "ask": "fix-no-repro-decision",
        "stop": "@stop"
      },
      "block": "diagnose"
    },
    {
      "id": "fix-no-repro-decision",
      "title": "Analyze \u2014 choose path forward when reproduction is uncertain",
      "phase": "analyze",
      "input": {
        "question": "workflow.question@v1",
        "evidence": "fix.diagnosis@v1"
      },
      "output": "fix.no-repro-decision@v1",
      "evidence_requirements": [
        "question",
        "available options",
        "selected option",
        "answer source"
      ],
      "execution": {
        "kind": "checkpoint"
      },
      "protocol": "fix-no-repro-decision@v1",
      "writes": {
        "checkpoint_request_path": "artifacts/checkpoints/fix-no-repro-decision-request.json",
        "checkpoint_response_path": "artifacts/checkpoints/fix-no-repro-decision-response.json"
      },
      "gate": {
        "allow": ["continue"]
      },
      "checkpoint_policy": {
        "prompt": "Diagnosis did not cleanly reproduce the bug. Choose how to proceed.",
        "choices": [
          {
            "id": "continue",
            "label": "Continue with a focused fix anyway"
          }
        ],
        "safe_default_choice": "continue",
        "safe_autonomous_choice": "continue"
      },
      "routes": {
        "continue": "fix-act",
        "revise": "fix-diagnose",
        "stop": "@stop",
        "handoff": "fix-handoff",
        "escalate": "@escalate"
      },
      "block": "human-decision"
    },
    {
      "id": "fix-act",
      "title": "Act \u2014 apply focused fix",
      "phase": "act",
      "input": {
        "brief": "fix.brief@v1",
        "diagnosis": "fix.diagnosis@v1"
      },
      "output": "fix.change@v1",
      "evidence_requirements": ["changed files", "change rationale", "declared follow-up proof"],
      "execution": {
        "kind": "dispatch",
        "role": "implementer"
      },
      "protocol": "fix-act@v1",
      "writes": {
        "artifact_path": "artifacts/fix/change.json",
        "request_path": "artifacts/dispatch/fix-act.request.json",
        "receipt_path": "artifacts/dispatch/fix-act.receipt.txt",
        "result_path": "artifacts/dispatch/fix-act.result.json"
      },
      "gate": {
        "pass": ["accept"]
      },
      "routes": {
        "continue": "fix-verify",
        "retry": "fix-act",
        "ask": "fix-no-repro-decision",
        "stop": "@stop",
        "handoff": "fix-handoff"
      },
      "block": "act"
    },
    {
      "id": "fix-verify",
      "title": "Verify \u2014 run Fix proof",
      "phase": "verify",
      "input": {
        "proof": "verification.plan@v1",
        "brief": "fix.brief@v1",
        "change": "fix.change@v1"
      },
      "output": "fix.verification@v1",
      "evidence_requirements": ["command list", "exit status", "bounded output", "pass or fail"],
      "execution": {
        "kind": "verification"
      },
      "protocol": "fix-verify@v1",
      "writes": {
        "artifact_path": "artifacts/fix/verification.json"
      },
      "gate": {
        "required": ["overall_status", "commands"]
      },
      "routes": {
        "continue": "fix-review",
        "retry": "fix-act",
        "ask": "fix-no-repro-decision",
        "stop": "@stop"
      },
      "route_overrides": {
        "continue": {
          "lite": "fix-close-lite"
        }
      },
      "block": "run-verification"
    },
    {
      "id": "fix-review",
      "title": "Review \u2014 independent audit of Fix change",
      "phase": "review",
      "input": {
        "brief": "fix.brief@v1",
        "change": "fix.change@v1",
        "verification": "fix.verification@v1"
      },
      "output": "fix.review@v1",
      "evidence_requirements": ["verdict", "findings", "confidence", "required fixes"],
      "execution": {
        "kind": "dispatch",
        "role": "reviewer"
      },
      "protocol": "fix-review@v1",
      "writes": {
        "artifact_path": "artifacts/fix/review.json",
        "request_path": "artifacts/dispatch/fix-review.request.json",
        "receipt_path": "artifacts/dispatch/fix-review.receipt.txt",
        "result_path": "artifacts/dispatch/fix-review.result.json"
      },
      "gate": {
        "pass": ["accept", "accept-with-fixes"]
      },
      "routes": {
        "continue": "fix-close",
        "retry": "fix-act",
        "revise": "fix-act",
        "ask": "fix-no-repro-decision",
        "stop": "@stop"
      },
      "block": "review"
    },
    {
      "id": "fix-close-lite",
      "title": "Close (lite) \u2014 emit Fix result without review",
      "phase": "close",
      "input": {
        "brief": "fix.brief@v1",
        "context": "fix.context@v1",
        "diagnosis": "fix.diagnosis@v1",
        "change": "fix.change@v1",
        "verification": "fix.verification@v1"
      },
      "output": "fix.result@v1",
      "evidence_requirements": ["outcome", "evidence pointers", "residual risks", "follow-ups"],
      "execution": {
        "kind": "synthesis"
      },
      "protocol": "fix-close-lite@v1",
      "writes": {
        "artifact_path": "artifacts/fix-result.json"
      },
      "gate": {
        "required": [
          "summary",
          "outcome",
          "verification_status",
          "regression_status",
          "review_status",
          "artifact_pointers"
        ]
      },
      "routes": {
        "complete": "@complete",
        "stop": "@stop",
        "handoff": "fix-handoff",
        "escalate": "@escalate"
      },
      "block": "close-with-evidence"
    },
    {
      "id": "fix-close",
      "title": "Close \u2014 emit Fix result",
      "phase": "close",
      "input": {
        "brief": "fix.brief@v1",
        "context": "fix.context@v1",
        "diagnosis": "fix.diagnosis@v1",
        "change": "fix.change@v1",
        "verification": "fix.verification@v1",
        "review": "fix.review@v1"
      },
      "output": "fix.result@v1",
      "evidence_requirements": ["outcome", "evidence pointers", "residual risks", "follow-ups"],
      "execution": {
        "kind": "synthesis"
      },
      "protocol": "fix-close@v1",
      "writes": {
        "artifact_path": "artifacts/fix-result.json"
      },
      "gate": {
        "required": [
          "summary",
          "outcome",
          "verification_status",
          "regression_status",
          "review_status",
          "review_verdict",
          "artifact_pointers"
        ]
      },
      "routes": {
        "complete": "@complete",
        "stop": "@stop",
        "handoff": "fix-handoff",
        "escalate": "@escalate"
      },
      "block": "close-with-evidence"
    },
    {
      "id": "fix-handoff",
      "title": "Persist Fix handoff",
      "phase": "close",
      "input": {
        "state": "workflow.state@v1",
        "brief": "fix.brief@v1"
      },
      "output": "continuity.record@v1",
      "evidence_requirements": [
        "goal",
        "completed moves",
        "pending evidence",
        "next action",
        "known debt"
      ],
      "execution": {
        "kind": "synthesis"
      },
      "protocol": "fix-handoff@v1",
      "writes": {
        "artifact_path": "artifacts/fix/handoff.json"
      },
      "gate": {
        "required": ["goal", "next_action"]
      },
      "routes": {
        "complete": "@handoff",
        "stop": "@stop"
      },
      "block": "handoff"
    }
  ]
}
