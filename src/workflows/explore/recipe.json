{
  "schema_version": "1",
  "id": "explore",
  "title": "Explore Recipe",
  "purpose": "Phase 2 first-parity target workflow per ADR-0007 CC#P2-1. Full-spine investigation: frame → analyze → synthesize → review → close. Canonical phase set {frame, analyze, act, review, close} with omits=[plan, verify] per explore contract §Canonical phase set. Synthesize and Review are worker-dispatch steps per ADR-0008 (distinct-adapter Knight-Leveson boundary crossings); Frame, Analyze, and Close remain orchestrator-synthesis (framing, decomposition, aggregation).",
  "status": "active",
  "version": "0.1.0",
  "starts_at": "frame-step",
  "initial_contracts": ["task.intake@v1", "route.decision@v1", "context.packet@v1"],
  "contract_aliases": [
    { "generic": "workflow.brief@v1", "actual": "explore.brief@v1" },
    { "generic": "diagnosis.result@v1", "actual": "explore.analysis@v1" },
    { "generic": "change.evidence@v1", "actual": "explore.synthesis@v1" },
    { "generic": "review.verdict@v1", "actual": "explore.review-verdict@v1" },
    { "generic": "workflow.result@v1", "actual": "explore.result@v1" }
  ],
  "entry": {
    "signals": {
      "include": ["explore", "investigate", "research", "understand"],
      "exclude": []
    },
    "intent_prefixes": ["explore", "investigate"]
  },
  "entry_modes": [
    {
      "name": "default",
      "rigor": "standard",
      "description": "Default explore entry mode — seeds the run at Frame. Standard rigor per ADR-0007 CC#P2-6 resolution of plan Open Question #5."
    }
  ],
  "spine_policy": {
    "mode": "partial",
    "omits": ["plan", "verify"],
    "rationale": "Explore is an investigation workflow — plan-mode is folded into Frame (investigation scoping); verify is omitted because explore output is not executable and does not admit mechanical verification. Review is the adversarial pass that IS in scope and, per ADR-0008, is a distinct-adapter review dispatch (not a weaker substitute for verify as previously described at v0.1 authoring). See specs/contracts/explore.md §Canonical phase set for the full rationale."
  },
  "phases": [
    { "canonical": "frame", "id": "frame-phase", "title": "Frame" },
    { "canonical": "analyze", "id": "analyze-phase", "title": "Analyze" },
    { "canonical": "act", "id": "synthesize-phase", "title": "Synthesize" },
    { "canonical": "review", "id": "review-phase", "title": "Review" },
    { "canonical": "close", "id": "close-phase", "title": "Close" }
  ],
  "items": [
    {
      "id": "frame-step",
      "uses": "frame",
      "title": "Frame — produce explore.brief",
      "phase": "frame",
      "input": {
        "task": "task.intake@v1",
        "route": "route.decision@v1"
      },
      "output": "explore.brief@v1",
      "evidence_requirements": ["scope boundary", "constraints", "proof plan"],
      "execution": { "kind": "synthesis" },
      "protocol": "explore-frame@v1",
      "writes": {
        "artifact_path": "artifacts/brief.json"
      },
      "gate": { "required": ["subject", "success_condition"] },
      "routes": {
        "continue": "analyze-step",
        "stop": "@stop"
      }
    },
    {
      "id": "analyze-step",
      "uses": "diagnose",
      "title": "Analyze — produce explore.analysis",
      "phase": "analyze",
      "input": {
        "brief": "explore.brief@v1",
        "context": "context.packet@v1"
      },
      "output": "explore.analysis@v1",
      "evidence_requirements": [
        "cause hypothesis",
        "confidence",
        "reproduction status",
        "diagnostic path"
      ],
      "execution": { "kind": "synthesis" },
      "protocol": "explore-analyze@v1",
      "writes": {
        "artifact_path": "artifacts/analysis.json"
      },
      "gate": { "required": ["aspects"] },
      "routes": {
        "continue": "synthesize-step",
        "retry": "analyze-step",
        "stop": "@stop"
      }
    },
    {
      "id": "synthesize-step",
      "uses": "act",
      "title": "Synthesize — produce explore.synthesis (adapter-bound dispatch per ADR-0008)",
      "phase": "act",
      "input": {
        "brief": "explore.brief@v1",
        "diagnosis": "explore.analysis@v1"
      },
      "output": "explore.synthesis@v1",
      "evidence_requirements": ["changed files", "change rationale", "declared follow-up proof"],
      "execution": { "kind": "dispatch", "role": "implementer" },
      "protocol": "explore-synthesize@v1",
      "writes": {
        "artifact_path": "artifacts/synthesis.json",
        "request_path": "artifacts/dispatch/synthesize.request.json",
        "receipt_path": "artifacts/dispatch/synthesize.receipt.txt",
        "result_path": "artifacts/dispatch/synthesize.result.json"
      },
      "gate": { "pass": ["accept"] },
      "routes": {
        "continue": "review-step",
        "retry": "synthesize-step",
        "stop": "@stop"
      }
    },
    {
      "id": "review-step",
      "uses": "review",
      "title": "Review — adversarial pass over synthesis (adapter-bound dispatch per ADR-0008)",
      "phase": "review",
      "input": {
        "brief": "explore.brief@v1",
        "diagnosis": "explore.analysis@v1",
        "change": "explore.synthesis@v1"
      },
      "output": "explore.review-verdict@v1",
      "evidence_requirements": ["verdict", "findings", "confidence", "required fixes"],
      "execution": { "kind": "dispatch", "role": "reviewer" },
      "protocol": "explore-review@v1",
      "writes": {
        "artifact_path": "artifacts/review-verdict.json",
        "request_path": "artifacts/dispatch/review.request.json",
        "receipt_path": "artifacts/dispatch/review.receipt.txt",
        "result_path": "artifacts/dispatch/review.result.json"
      },
      "gate": { "pass": ["accept", "accept-with-fold-ins"] },
      "routes": {
        "continue": "close-step",
        "retry": "synthesize-step",
        "revise": "synthesize-step",
        "stop": "@stop"
      }
    },
    {
      "id": "close-step",
      "uses": "close-with-evidence",
      "title": "Close — emit final result artifact",
      "phase": "close",
      "input": {
        "brief": "explore.brief@v1",
        "synthesis": "explore.synthesis@v1",
        "review": "explore.review-verdict@v1"
      },
      "output": "explore.result@v1",
      "evidence_requirements": ["outcome", "evidence pointers", "residual risks", "follow-ups"],
      "execution": { "kind": "synthesis" },
      "protocol": "explore-close@v1",
      "writes": {
        "artifact_path": "artifacts/explore-result.json"
      },
      "gate": { "required": ["summary", "verdict_snapshot"] },
      "routes": {
        "complete": "@complete",
        "stop": "@stop"
      }
    }
  ]
}
