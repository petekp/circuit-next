{
  "schema_version": "1",
  "id": "fix-candidate",
  "title": "Fix Candidate Recipe",
  "purpose": "Design-only candidate showing how a clear Fix workflow can be assembled from reusable primitives before any recipe runner exists.",
  "status": "candidate",
  "starts_at": "fix-intake",
  "initial_contracts": [
    "user.goal@v1",
    "workflow.catalog@v1",
    "context.request@v1",
    "workflow.question@v1",
    "verification.plan@v1",
    "workflow.state@v1"
  ],
  "contract_aliases": [
    {
      "generic": "workflow.brief@v1",
      "actual": "fix.brief@v1"
    },
    {
      "generic": "context.packet@v1",
      "actual": "fix.context@v1"
    },
    {
      "generic": "diagnosis.result@v1",
      "actual": "fix.diagnosis@v1"
    },
    {
      "generic": "decision.answer@v1",
      "actual": "fix.no-repro-decision@v1"
    },
    {
      "generic": "workflow.evidence@v1",
      "actual": "fix.diagnosis@v1"
    },
    {
      "generic": "change.evidence@v1",
      "actual": "fix.change@v1"
    },
    {
      "generic": "verification.result@v1",
      "actual": "fix.verification@v1"
    },
    {
      "generic": "review.verdict@v1",
      "actual": "fix.review@v1"
    },
    {
      "generic": "workflow.result@v1",
      "actual": "fix.result@v1"
    }
  ],
  "items": [
    {
      "id": "fix-intake",
      "uses": "intake",
      "title": "Capture fix request",
      "phase": "frame",
      "input": {
        "goal": "user.goal@v1"
      },
      "output": "task.intake@v1",
      "evidence_requirements": ["normalized goal", "requested workflow", "operator constraints"],
      "execution": {
        "kind": "synthesis"
      },
      "routes": {
        "continue": "fix-route",
        "ask": "@stop",
        "stop": "@stop"
      }
    },
    {
      "id": "fix-route",
      "uses": "route",
      "title": "Confirm fix path",
      "phase": "frame",
      "input": {
        "task": "task.intake@v1",
        "catalog": "workflow.catalog@v1"
      },
      "output": "route.decision@v1",
      "evidence_requirements": [
        "selected workflow",
        "selection reason",
        "fallback reason when conservative"
      ],
      "execution": {
        "kind": "synthesis"
      },
      "routes": {
        "continue": "fix-frame",
        "ask": "@stop",
        "stop": "@stop"
      }
    },
    {
      "id": "fix-frame",
      "uses": "frame",
      "title": "Frame problem boundary",
      "phase": "frame",
      "input": {
        "task": "task.intake@v1",
        "route": "route.decision@v1"
      },
      "output": "fix.brief@v1",
      "evidence_requirements": ["scope boundary", "constraints", "proof plan"],
      "execution": {
        "kind": "synthesis"
      },
      "routes": {
        "continue": "fix-gather-context",
        "revise": "fix-frame",
        "ask": "@stop",
        "stop": "@stop"
      }
    },
    {
      "id": "fix-gather-context",
      "uses": "gather-context",
      "title": "Gather problem context",
      "phase": "analyze",
      "input": {
        "brief": "fix.brief@v1",
        "request": "context.request@v1"
      },
      "output": "fix.context@v1",
      "evidence_requirements": ["source list", "observations", "confidence notes"],
      "execution": {
        "kind": "dispatch",
        "role": "researcher"
      },
      "routes": {
        "continue": "fix-diagnose",
        "retry": "fix-gather-context",
        "ask": "@stop",
        "stop": "@stop"
      }
    },
    {
      "id": "fix-diagnose",
      "uses": "diagnose",
      "title": "Diagnose problem",
      "phase": "analyze",
      "input": {
        "brief": "fix.brief@v1",
        "context": "fix.context@v1"
      },
      "output": "fix.diagnosis@v1",
      "evidence_requirements": [
        "cause hypothesis",
        "confidence",
        "reproduction status",
        "diagnostic path"
      ],
      "execution": {
        "kind": "dispatch",
        "role": "researcher"
      },
      "routes": {
        "continue": "fix-act",
        "retry": "fix-gather-context",
        "ask": "fix-no-repro-decision",
        "stop": "@stop"
      }
    },
    {
      "id": "fix-no-repro-decision",
      "uses": "human-decision",
      "title": "Choose uncertain-evidence next step",
      "phase": "analyze",
      "input": {
        "question": "workflow.question@v1",
        "evidence": "fix.diagnosis@v1"
      },
      "output": "fix.no-repro-decision@v1",
      "evidence_requirements": [
        "question",
        "available options",
        "selected option",
        "answer source"
      ],
      "execution": {
        "kind": "checkpoint"
      },
      "routes": {
        "continue": "fix-act",
        "revise": "fix-diagnose",
        "stop": "@stop",
        "handoff": "fix-handoff",
        "escalate": "@escalate"
      }
    },
    {
      "id": "fix-act",
      "uses": "act",
      "title": "Apply focused fix",
      "phase": "act",
      "input": {
        "brief": "fix.brief@v1",
        "diagnosis": "fix.diagnosis@v1"
      },
      "output": "fix.change@v1",
      "evidence_requirements": ["changed files", "change rationale", "declared follow-up proof"],
      "execution": {
        "kind": "dispatch",
        "role": "implementer"
      },
      "routes": {
        "continue": "fix-verify",
        "retry": "fix-act",
        "ask": "fix-no-repro-decision",
        "stop": "@stop",
        "handoff": "fix-handoff"
      }
    },
    {
      "id": "fix-verify",
      "uses": "run-verification",
      "title": "Run fix proof",
      "phase": "verify",
      "input": {
        "proof": "verification.plan@v1",
        "change": "fix.change@v1"
      },
      "output": "fix.verification@v1",
      "evidence_requirements": ["command list", "exit status", "bounded output", "pass or fail"],
      "execution": {
        "kind": "verification"
      },
      "routes": {
        "continue": "fix-review",
        "retry": "fix-act",
        "ask": "fix-no-repro-decision",
        "stop": "@stop"
      },
      "route_overrides": {
        "continue": {
          "lite": "fix-close-lite"
        }
      }
    },
    {
      "id": "fix-review",
      "uses": "review",
      "title": "Review fix result",
      "phase": "review",
      "input": {
        "brief": "fix.brief@v1",
        "change": "fix.change@v1",
        "verification": "fix.verification@v1"
      },
      "output": "fix.review@v1",
      "evidence_requirements": ["verdict", "findings", "confidence", "required fixes"],
      "execution": {
        "kind": "dispatch",
        "role": "reviewer"
      },
      "routes": {
        "continue": "fix-close",
        "retry": "fix-act",
        "revise": "fix-act",
        "ask": "fix-no-repro-decision",
        "stop": "@stop"
      }
    },
    {
      "id": "fix-close-lite",
      "uses": "close-with-evidence",
      "title": "Close lite fix with evidence",
      "phase": "close",
      "input": {
        "brief": "fix.brief@v1",
        "context": "fix.context@v1",
        "diagnosis": "fix.diagnosis@v1",
        "change": "fix.change@v1",
        "verification": "fix.verification@v1"
      },
      "output": "fix.result@v1",
      "evidence_requirements": ["outcome", "evidence pointers", "residual risks", "follow-ups"],
      "execution": {
        "kind": "synthesis"
      },
      "routes": {
        "complete": "@complete",
        "stop": "@stop",
        "handoff": "fix-handoff",
        "escalate": "@escalate"
      }
    },
    {
      "id": "fix-close",
      "uses": "close-with-evidence",
      "title": "Close fix with evidence",
      "phase": "close",
      "input": {
        "brief": "fix.brief@v1",
        "context": "fix.context@v1",
        "diagnosis": "fix.diagnosis@v1",
        "change": "fix.change@v1",
        "verification": "fix.verification@v1",
        "review": "fix.review@v1"
      },
      "output": "fix.result@v1",
      "evidence_requirements": ["outcome", "evidence pointers", "residual risks", "follow-ups"],
      "execution": {
        "kind": "synthesis"
      },
      "routes": {
        "complete": "@complete",
        "stop": "@stop",
        "handoff": "fix-handoff",
        "escalate": "@escalate"
      }
    },
    {
      "id": "fix-handoff",
      "uses": "handoff",
      "title": "Persist fix handoff",
      "phase": "close",
      "input": {
        "state": "workflow.state@v1",
        "brief": "fix.brief@v1"
      },
      "output": "continuity.record@v1",
      "evidence_requirements": [
        "goal",
        "completed moves",
        "pending evidence",
        "next action",
        "known debt"
      ],
      "execution": {
        "kind": "synthesis"
      },
      "routes": {
        "complete": "@handoff",
        "stop": "@stop"
      }
    }
  ]
}
