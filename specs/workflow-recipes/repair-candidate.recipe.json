{
  "schema_version": "1",
  "id": "repair-candidate",
  "title": "Repair Candidate Recipe",
  "purpose": "Design-only candidate showing how Repair can be assembled from reusable primitives before any recipe runner exists.",
  "status": "candidate",
  "starts_at": "repair-intake",
  "initial_contracts": [
    "user.goal@v1",
    "workflow.catalog@v1",
    "context.request@v1",
    "workflow.question@v1",
    "verification.plan@v1",
    "workflow.state@v1"
  ],
  "contract_aliases": [
    {
      "generic": "workflow.brief@v1",
      "actual": "repair.brief@v1"
    },
    {
      "generic": "context.packet@v1",
      "actual": "repair.context@v1"
    },
    {
      "generic": "diagnosis.result@v1",
      "actual": "repair.diagnosis@v1"
    },
    {
      "generic": "decision.answer@v1",
      "actual": "repair.no-repro-decision@v1"
    },
    {
      "generic": "change.evidence@v1",
      "actual": "repair.fix@v1"
    },
    {
      "generic": "verification.result@v1",
      "actual": "repair.verification@v1"
    },
    {
      "generic": "review.verdict@v1",
      "actual": "repair.review@v1"
    },
    {
      "generic": "workflow.result@v1",
      "actual": "repair.result@v1"
    }
  ],
  "items": [
    {
      "id": "repair-intake",
      "uses": "intake",
      "title": "Capture repair request",
      "input": {
        "goal": "user.goal@v1"
      },
      "output": "task.intake@v1",
      "routes": {
        "continue": "repair-route",
        "ask": "@stop",
        "stop": "@stop"
      }
    },
    {
      "id": "repair-route",
      "uses": "route",
      "title": "Confirm repair path",
      "input": {
        "task": "task.intake@v1",
        "catalog": "workflow.catalog@v1"
      },
      "output": "route.decision@v1",
      "routes": {
        "continue": "repair-frame",
        "ask": "@stop",
        "stop": "@stop"
      }
    },
    {
      "id": "repair-frame",
      "uses": "frame",
      "title": "Frame bug boundary",
      "input": {
        "task": "task.intake@v1",
        "route": "route.decision@v1"
      },
      "output": "repair.brief@v1",
      "routes": {
        "continue": "repair-gather-context",
        "revise": "repair-frame",
        "ask": "@stop",
        "stop": "@stop"
      }
    },
    {
      "id": "repair-gather-context",
      "uses": "gather-context",
      "title": "Gather bug context",
      "input": {
        "brief": "repair.brief@v1",
        "request": "context.request@v1"
      },
      "output": "repair.context@v1",
      "routes": {
        "continue": "repair-diagnose",
        "retry": "repair-gather-context",
        "ask": "@stop",
        "stop": "@stop"
      }
    },
    {
      "id": "repair-diagnose",
      "uses": "diagnose",
      "title": "Diagnose root cause",
      "input": {
        "brief": "repair.brief@v1",
        "context": "repair.context@v1"
      },
      "output": "repair.diagnosis@v1",
      "routes": {
        "continue": "repair-fix",
        "retry": "repair-gather-context",
        "ask": "repair-no-repro-decision",
        "stop": "@stop"
      }
    },
    {
      "id": "repair-no-repro-decision",
      "uses": "human-decision",
      "title": "Choose no-repro next step",
      "input": {
        "question": "workflow.question@v1",
        "evidence": "repair.diagnosis@v1"
      },
      "output": "repair.no-repro-decision@v1",
      "routes": {
        "continue": "repair-fix",
        "revise": "repair-diagnose",
        "stop": "@stop",
        "handoff": "repair-handoff",
        "escalate": "@escalate"
      }
    },
    {
      "id": "repair-fix",
      "uses": "act",
      "title": "Apply focused fix",
      "input": {
        "brief": "repair.brief@v1",
        "diagnosis": "repair.diagnosis@v1",
        "decision": "repair.no-repro-decision@v1"
      },
      "output": "repair.fix@v1",
      "routes": {
        "continue": "repair-verify",
        "retry": "repair-fix",
        "ask": "repair-no-repro-decision",
        "stop": "@stop",
        "handoff": "repair-handoff"
      }
    },
    {
      "id": "repair-verify",
      "uses": "run-verification",
      "title": "Run repair proof",
      "input": {
        "proof": "verification.plan@v1",
        "change": "repair.fix@v1"
      },
      "output": "repair.verification@v1",
      "routes": {
        "continue": "repair-review",
        "retry": "repair-fix",
        "ask": "repair-no-repro-decision",
        "stop": "@stop"
      }
    },
    {
      "id": "repair-review",
      "uses": "review",
      "title": "Review repair result",
      "input": {
        "brief": "repair.brief@v1",
        "change": "repair.fix@v1",
        "verification": "repair.verification@v1"
      },
      "output": "repair.review@v1",
      "routes": {
        "continue": "repair-close",
        "retry": "repair-fix",
        "revise": "repair-fix",
        "ask": "repair-no-repro-decision",
        "stop": "@stop"
      }
    },
    {
      "id": "repair-close",
      "uses": "close-with-evidence",
      "title": "Close repair with evidence",
      "input": {
        "brief": "repair.brief@v1",
        "verification": "repair.verification@v1",
        "review": "repair.review@v1"
      },
      "output": "repair.result@v1",
      "routes": {
        "complete": "@complete",
        "stop": "@stop",
        "handoff": "repair-handoff",
        "escalate": "@escalate"
      }
    },
    {
      "id": "repair-handoff",
      "uses": "handoff",
      "title": "Persist repair handoff",
      "input": {
        "state": "workflow.state@v1",
        "brief": "repair.brief@v1"
      },
      "output": "continuity.record@v1",
      "routes": {
        "complete": "@handoff",
        "stop": "@stop"
      }
    }
  ]
}
